# Upload limitlerini (Laravel PDF 50MB doğrulaması için) yükselt
php_value upload_max_filesize 64M
php_value post_max_size 64M


# --- Laravel için gereken kısım buradan sonra başlıyor ---
<IfModule mod_rewrite.c>
    # Symlink’i (public/storage) takip edebilmek için
    Options +SymLinksIfOwnerMatch +FollowSymLinks

    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Symlink dosyaları doğrudan sun (public/storage)
    RewriteCond %{REQUEST_FILENAME} -l
    RewriteRule ^ - [L]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
# --- Laravel kısmı bitti ---
